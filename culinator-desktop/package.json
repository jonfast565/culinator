    "vue": "^3.5.13",
    "vue-codemirror": "^6.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.8.4",
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.4.0",
    "postcss": "^8.4.49",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
