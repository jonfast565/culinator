document       = "culinator", version, ";", recipe ;
recipe         = "recipe", identifier, [ "as", type_ref ], block ;
block          = "{", { declaration | property }, "}" ;
declaration    = type_decl | resource_decl | formula_decl | process_decl | operation_decl | prep_decl | yield_decl | serving_decl ;
type_decl      = "type", identifier, "as", type_ref, block ;
resource_decl  = resource_kind, identifier, [ "as", type_ref ], [ measurement ], block
               | "resource", identifier, "as", type_ref, [ measurement ], block ;
(* A resource block may carry a `state` property (a `property`, see below) to
   annotate qualitative condition, e.g. `state ripe;`, `state melted;`. It may
   also carry these recognized flags/lists (parsed into typed fields):
     `optional true;`            - ingredient is optional (garnish, "plus more")
     `divided true;`             - one ingredient split across steps
     `substitutes [a, b];`       - acceptable substitutions
   A `quantity` may be a range, e.g. `quantity 2 to 3 clove;` (see `value`). *)
resource_kind  = "ingredient" | "material" | "container" | "equipment" | "environment" | "labor" ;
measurement    = "measured", "by", dimension ;
dimension      = "mass" | "volume" | "count" | "time" | "temperature" | "length" | "area" | "energy" | "ratio" | "concentration" ;
formula_decl   = "formula", identifier, formula_basis, "{", { formula_ingredient | property }, "}" ;
formula_basis  = [ "as", type_ref ] | [ "relative", "to", identifier ] | [ "of", "total" ] ;
formula_ingredient = "ingredient", identifier, [ "as", type_ref ], [ measurement ], block ;
process_decl   = "process", identifier, [ "as", type_ref ], "{", { process_decl | operation_decl | property }, "}" ;
operation_decl = "operation", identifier, ( [ "as", type_ref ] | [ "does", identifier ] ), op_block ;
op_block       = "{", { op_field | property }, "}" ;
op_field       = labor_field | after_field | binding_field | requires_field
               | duration_field | temperature_field | heat_field | until_field
               | optional_field ;
labor_field    = "labor", ( "active" | "passive" | "monitor" | "automated" ), ";" ;
after_field    = "after", ( "[", identifier, { ",", identifier }, "]"
                          | identifier, { dep_modifier } ), ";" ;
dep_modifier   = "start_start" | "finish_finish" | "start_finish"
               | ( "lag", quantity ) | "optional" ;
binding_role   = "input" | "output" | "produces" | "target" | "tool" | "container" | "equipment" ;
binding_field  = binding_role, ( "[", identifier, { ",", identifier }, "]"
                               | identifier, [ quantity ] ), ";" ;   (* single form may carry a per-step amount *)
requires_field = "requires", { token }, ";" ;
(* A single fixed time, an inclusive range, or an open-ended holding ceiling.
   The optional `estimated` keyword marks the time as a soft guideline. *)
duration_field = "duration", [ "estimated" ],
                 ( quantity, [ "to", quantity ] | "up", "to", quantity ), ";" ;
(* Numeric temperature setpoint (oven/oil/target), distinct from `heat`. *)
temperature_field = "temperature", quantity, ";" ;
heat_field     = "heat", ( "low" | "medium_low" | "medium" | "medium_high" | "high" ), ";" ;
(* A typed "cook until…" doneness cue. `internal_temp` takes a quantity; the
   others take a descriptive string (or symbol). *)
until_field    = "until", ( "internal_temp" | "visual" | "tester" | "texture" | "rise" ), value, ";" ;
optional_field = "optional", [ ( "true" | "false" ) ], ";" ;
(* `prep <verb> <ingredient> [into <output>]` is sugar for an operation named
   `<verb>_<ingredient>` that takes the ingredient as input and produces the
   output material (defaulting to `<ingredient>_<verb>`). The optional block
   accepts the same properties as an operation (duration, labor, after, ...). *)
prep_decl      = "prep", identifier, identifier, [ "into", identifier ], ( ";" | block ) ;
yield_decl     = "yield", identifier, [ "as", type_ref ], [ measurement ], block ;
serving_decl   = "serving", identifier, [ "as", type_ref ], [ measurement ], block ;
property       = identifier, value, ";" ;
type_ref       = identifier, [ "<", type_ref, { ",", type_ref }, ">" ] ;
value          = string | number | percentage | quantity | range | identifier | list ;
quantity       = number, identifier ;   (* the identifier is the unit; see below *)
(* Units are classified into a `dimension` case-insensitively (see
   `Dimension::from_unit` in culinator-core). Recognized cooking units include:
     mass:        g/gram(s), kg/kilogram(s), mg, oz/ounce(s), lb/pound(s), dram
     volume:      ml/cc, cl, dl, l/liter(s), cup(s), tbsp/tablespoon(s),
                  tsp/teaspoon(s), floz, pt/pint(s), qt/quart(s), gal/gallon(s),
                  dash, pinch, smidgen, drop
     temperature: c/celsius, f/fahrenheit, k/kelvin
     time:        s/sec/second(s), min/minute(s), h/hr/hour(s), day(s), wk/week(s)
     length:      mm, cm, m/meter(s), in/inch(es), ft/foot/feet
     count:       each, ea, count, dozen, clove(s), stick(s), piece(s), slice(s),
                  can(s), package(s)/pkg, bunch(es), head(s), bulb(s), sprig(s),
                  stalk(s), leaf/leaves, ear(s), fillet(s), strip(s), wedge(s),
                  cube(s), loaf/loaves, sheet(s), scoop(s), handful(s), ...
   Any unrecognized unit is kept verbatim and classified as `ratio`. *)
(* Inclusive range, e.g. `2 to 3 clove` or `15 min to 20 min`. The unit may
   appear on the upper bound only, or on both bounds. *)
range          = ( number | quantity ), "to", ( number | quantity ) ;
list           = "[", [ value, { ",", value } ], "]" ;

(* Recipe-book document root *)
document        = protocol_header, ( recipe | recipe_book ) ;
recipe_book     = ( "book" | "recipe_book" ), identifier, [ "as", type_ref ], "{", { book_member }, "}" ;
book_member     = title_property | description_property | recipe | property ;
description_property = "description", string, ";" ;
